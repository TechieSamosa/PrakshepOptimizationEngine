.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# ──────────────────────────────────────────────────────────────────────────────
