# ============================================================================
# Prakshep Optimization Engine — .gitignore
# Comprehensive exclusions for C++ / Python / Node.js / Full-Stack project
# ============================================================================

# ──────────────────────────────────────────────────────────────────────────────
#  C++ Build Artifacts
# ──────────────────────────────────────────────────────────────────────────────
build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.o
*.obj
*.so
*.so.*
*.dll
*.dylib
*.pyd
*.lib
*.a
*.exp
*.ilk
*.pdb
*.idb
*.dSYM/
*.exe
*.out
compile_commands.json

# ──────────────────────────────────────────────────────────────────────────────
#  Python
# ──────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.eggs/
*.egg-info/
*.egg
dist/
sdist/
wheels/
*.whl
.env
.venv/
venv/
ENV/
env/
pip-log.txt
pip-delete-this-directory.txt
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.tox/
.nox/

# ──────────────────────────────────────────────────────────────────────────────
#  Node.js / Next.js
# ──────────────────────────────────────────────────────────────────────────────
node_modules/
.next/
out/
.turbo/
.vercel/
.nuxt/
.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
yarn.lock
pnpm-lock.yaml

