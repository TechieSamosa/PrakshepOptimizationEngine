{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://prakshep-api.onrender.com/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "wss://prakshep-api.onrender.com/ws/:path*"
    }
  ]
}
